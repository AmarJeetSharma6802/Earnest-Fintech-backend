generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum CityEnum {
  DELHI
  GURUGRAM
  NOIDA
  BANGALORE
  KOLKATA
  CHANDIGARH
  UP
}

model Booking {
  id               String   @id @default(uuid())
  
  fullName         String
  phone            String
  
  city             CityEnum
  
  appointmentDate  DateTime   // actual visit date
  appointmentTime  String     // "17:00" (simple rakhte hain)

  createdAt        DateTime @default(now())

  // optional tracking
  bookingCount     Int       @default(1)
}